import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
import seaborn as sns
import joblib
from scipy import stats
from scipy.stats import shapiro
from scipy.stats import pearsonr


df = pd.read_csv("./data/train_clean.csv")


df.describe()


plt.figure(figsize=(10,6))

sns.histplot(
    data=df,
    x="Annual_Income",
    bins=70
)

plt.title("Distribution de l'Annual Income selon le Credit Score")
plt.xlabel("Annual Income")
plt.ylabel("Densité")
plt.show()


plt.figure(figsize=(10, 6))

for score in df["Credit_Score"].unique():
    subset = df[df["Credit_Score"] == score]

    sns.histplot(
        subset["Annual_Income"],
        kde=True,
        stat="density",
        label=score,
        alpha=0.3
    )

plt.title("Distribution de Annual_Income selon Credit_Score")
plt.xlabel("Annual_Income")
plt.ylabel("Densité")
plt.legend(title="Credit_Score")

plt.tight_layout()
plt.savefig("figures/hist_kde_annual_income.png")
plt.close()



